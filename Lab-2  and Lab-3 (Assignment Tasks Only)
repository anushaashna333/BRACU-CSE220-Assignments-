public static Node alternateMerge( Node head1, Node head2 ){
        Node curr1 = head1;
        Node curr2 = head2;
        while(curr1!=null && curr2!=null){
            Node temp = curr2;
            Node tail = curr1.next;
            curr2 = curr2.next;
            temp.next = tail;
            curr1.next = temp;
            curr1 = tail;
        }
        head2 = null;  
        return head1;
    }



