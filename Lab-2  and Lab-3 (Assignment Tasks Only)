public static void sumOddAppend(Node dh) {
        // TO DO
        Node prev = dh;
        Node curr = dh.next;
        int sum = 0;
        Node temp = null;
        while(curr!=dh){
            if((Integer)curr.elem%2!=0){
                sum += (Integer)curr.elem;
                temp = new Node(sum);
                prev.next = curr.next;
            }
            prev = curr;
            curr = curr.next;
            if(curr.next==dh){
                curr.next = temp;
                temp.next = dh;
                break;
            }
        }
    }


