public static void rangeMove(DNode dh, int start, int end) {
        // TO DO
        DNode last = dh.prev;
        DNode original_last = dh.prev;
        DNode temp = null;
        boolean inRange = true;

        while(inRange){
            DNode curr = dh.next;
            DNode successor = curr.next;
            DNode predecessor = curr.prev;
            while(curr!=original_last.next){
                if((Integer)curr.elem>=start && (Integer)curr.elem<=end){
                    temp = curr;
                    predecessor.next = successor;
                    successor.prev = predecessor;

                    curr = curr.next;
                    successor = curr.next;
                    predecessor = curr.prev;
            

                    last.next = temp;
                    temp.prev = last;
                    dh.prev = temp;
                    temp.next = dh;
                    last = temp;
                    inRange = true;
                }
                else{
                    inRange = false;
                    curr = curr.next;
                    successor = curr.next;
                    predecessor = curr.prev;
                }
            }
        }
    }
