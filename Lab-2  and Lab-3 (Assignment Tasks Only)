public static String checkSimilar( Node building1, Node building2 ){   
        //TO DO
        Node temp_1 = building1;
        Node temp_2 = building2;
        String match = "Similar";
        if(temp_1==null || temp_2==null){
            return null;
        }
        while(temp_1!=null || temp_2!=null){
            if((temp_1!=null && temp_2==null) || (temp_2!=null && temp_1==null)){
                match = "Not Similar";
                break;
            }
            if(!temp_1.elem.equals(temp_2.elem)){
                match = "Not Similar";
                break;
            }
            else{
                 match = "Similar";
            }
            temp_1 = temp_1.next;
            temp_2 = temp_2.next;
        }
        return match;
    }

