public static Node idGenerator(Node head1, Node head2, Node head3) { 
      Node curr1 = head1;
      Node curr2 = head2;
      Node curr3 = head3;
      Node tail =head1;
      Node prev = null;

      while(curr1!=null){
        Node newNode = curr1.next;
        curr1.next = prev;
        prev = curr1;
        curr1 = newNode;
      }
       head1 = prev;
       Node temp = new Node (null);
       while(curr2!=null && curr3!=null){
         int num = (Integer)curr3.elem + (Integer)curr2.elem;
         if(num>=10){
            num %= 10;
         }
         temp = new Node(num);
         tail.next = temp;
         tail = temp;
         curr2 = curr2.next;
         curr3 = curr3.next;
       }
       return head1; 
    }


