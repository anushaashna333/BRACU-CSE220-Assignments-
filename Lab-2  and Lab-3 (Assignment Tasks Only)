public static void pairJoin(DNode dh1, DNode dh2) {
        // TO DO
        DNode curr1 = dh1.next;
        DNode curr2 = dh2.next;
        DNode temp1 = null;
        DNode temp2 = null;
        while(curr1!=null && curr2!=null){
            temp1 = curr1.next;
            temp2 = curr2.next;
            curr1.next = curr2;
            curr2.prev = curr1;
            if(temp2==null){
                curr2.next =dh1;
                dh1.prev = curr2;
                break;
            }
            curr2.next = temp1;
            temp1.prev = curr2;
            curr2 = temp2;
            curr1 = temp1;
        }
    }


