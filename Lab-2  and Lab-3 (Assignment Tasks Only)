public static Node organizeBooks(Node head, Integer[] popularity) { 
        //TO DO
        boolean switchingPlaces = true;
        int temp_arr = 0;

        while(switchingPlaces){
          int idx = 0;
          Node curr = head; 
          Node nextNode = head.next;
          Node prev = null;
          while(curr!=null && curr.next!=null && idx<popularity.length-1){
              if(popularity[idx]<popularity[idx+1]){
                  curr.next = nextNode.next;//
                  nextNode.next = curr;                  
                  if(idx==0){
                    head = nextNode;
                  }
                  else{
                    prev.next = nextNode;
                  }
                  prev = nextNode;
                    
                  temp_arr = popularity[idx];
                  popularity[idx] = popularity[idx+1];
                  popularity[idx+1] = temp_arr;
                    
                  nextNode = curr.next;
                  switchingPlaces = true;
              }
              else{
                switchingPlaces = false;
                prev = curr;
                curr = curr.next;
                nextNode = curr.next;
              } 
              idx++;
          }
        }
        return head;
    }



