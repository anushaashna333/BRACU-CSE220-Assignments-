public static Integer rowRotation( Integer examWeek, String[][] matrix ){

        //TO DO
        Integer row = matrix.length;
        Integer col = matrix[0].length;
        String temp = " ";
        Integer r_num = 0;

        int count = 0;
        while(count<examWeek-1){
            for(int i=0; i<col; i++){
                for(int j=0; j<row; j++){
                    if(j==0){
                        temp = matrix[j+1][i]; 
                        matrix[j+1][i] = matrix[j][i]; 
                        matrix[j][i] = temp;
                    }
                    else if(j>0 && j<row-1){
                        temp = matrix[j+1][i]; 
                        matrix[j+1][i] = matrix[0][i];
                        matrix[0][i] = temp;
                    }
                    else if(j==row-1){
                        temp = matrix[j][i];
                        matrix[j][i] = matrix[0][i];
                        matrix[j][i] = temp;
                    }
                }
            }
            count++;
        }

        for(int m=0; m<col; m++){
            for(int k=0; k<row; k++){
                if(matrix[k][m].equals("AA")){
                r_num = k;
                break;
                }
            }
        }
        Arr.print2D(matrix);
        return r_num+1;
    }

