public static void playGame( Integer[][] arena ){       
        //TO DO
        int row = arena.length;
        int col = arena[0].length;
        int point = 0;
        for(int i=0; i<row; i++){
            for(int j=0; j<col; j++){
                if(arena[i][j]!=0 && arena[i][j]%50==0){
                    if(arena[i][j]!=arena[0][j] && arena[i-1][j]==2){ //above
                        point+=2;  
                    }
                     if(arena[i][j]!=arena[row-1][j]  && arena[i+1][j]==2){ //below
                        point+=2;  
                     }
                    if(arena[i][j]!=arena[i][0] && arena[i][j-1]==2){ //left
                        point+=2;  
                    }
                    if(arena[i][j]!=arena[i][col-1] && arena[i][j+1]==2){ //right
                        point+=2;  
                    }
                }
            }
        }
      
      if(point>=10){
        System.out.println("Points Gained:  "+point+". Your team has survived the game.");
      }
      else{
        System.out.println("Points Gained:  "+point+". Your team is out.");
      }
    }

